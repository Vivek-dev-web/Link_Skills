# Postgres (Neon, Supabase, or any hosted provider)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
NEXTAUTH_SECRET="your-secret-here"

# Your production domain (or http://localhost:3001 for local dev)
NEXTAUTH_URL="https://your-project.vercel.app"

# Vercel Blob — auto-injected when you connect a Blob store on Vercel
# Leave blank for local dev (files save to public/uploads/ instead)
BLOB_READ_WRITE_TOKEN=""

# Optional OAuth — leave blank to use email/password only
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
LINKEDIN_CLIENT_ID=""
LINKEDIN_CLIENT_SECRET=""
