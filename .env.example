# ── Database (Neon recommended) ────────────────────────────────────────────
# Pooled URL  → used by the app at runtime (serverless-safe)
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require"
# Direct URL  → used by Prisma Migrate / db push (bypasses pooler)
DIRECT_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# ── NextAuth ────────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
NEXTAUTH_SECRET="your-secret-here"
# Your production domain (or http://localhost:3001 for local dev)
NEXTAUTH_URL="https://your-project.vercel.app"

# ── Vercel Blob (file uploads) ──────────────────────────────────────────────
# Auto-injected when you connect a Blob store in the Vercel dashboard.
# Leave blank for local dev (files save to public/uploads/ as fallback).
BLOB_READ_WRITE_TOKEN=""

# ── Optional OAuth ──────────────────────────────────────────────────────────
# Leave blank to use email/password auth only.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
LINKEDIN_CLIENT_ID=""
LINKEDIN_CLIENT_SECRET=""
