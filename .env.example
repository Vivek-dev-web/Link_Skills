# SQLite — no setup needed, file lives in prisma/dev.db
DATABASE_URL="file:./dev.db"

# Generate a real secret for production: `openssl rand -base64 32`
NEXTAUTH_SECRET="dev-secret-change-me-please-12345"
NEXTAUTH_URL="http://localhost:3000"

# Optional OAuth — leave blank to skip, app works fine with email/password only
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
LINKEDIN_CLIENT_ID=""
LINKEDIN_CLIENT_SECRET=""
